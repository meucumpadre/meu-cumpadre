            <div class="dc-node st-pass">D24</div><div class="dc-node st-na">D28</div><div class="dc-node st-pass">D31</div>
            <div class="dc-node st-na">D33</div><div class="dc-node st-pass">D36</div><div class="dc-node st-na">D40</div>
