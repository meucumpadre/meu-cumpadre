<!-- ============================================================
     P10 — APLICAÇÃO (Frente 6 bonus)
     ============================================================ -->
<section class="page" id="p10" aria-labelledby="p10-title" data-screen-label="10 Aplicação · decision trees + mocks">
  <div class="page-meta">
    <span>MC · Foundation v0.3 · Provisional</span>
    <span><span class="pm-num">10</span> / 10 · Aplicação · como usar este Design System</span>
  </div>
  <div class="page-eyebrow">Página 10</div>
  <h2 class="page-title" id="p10-title">Como usar este Design System</h2>
  <p class="page-lede">Meta-página. O Foundation se documentando para Carlos UX e próximos designers. Decision trees curtas para escolha rápida + três mocks de tela combinando os componentes em contexto real.</p>

  <div class="decision-trees">
    <div class="tree">
      <h4>Cor: Diamante · Ouro · Vermelho · Azul · Verde?</h4>
      <div class="t-q"><strong>É documento canônico selado?</strong></div>
      <div class="t-branch">Sim → Diamante 700 + Ouro 500 (selo)</div>
      <div class="t-q"><strong>É alerta de risco/dano?</strong></div>
      <div class="t-branch">Sim → Vermelho 700 (corpo) ou 500 (bg com texto branco)</div>
      <div class="t-q"><strong>É fluxo Acesso (WhatsApp/cidadão)?</strong></div>
      <div class="t-branch">Sim → Azul 700 (corpo) + raio 16px</div>
      <div class="t-q"><strong>É confirmação/proteção/SELADO?</strong></div>
      <div class="t-branch">Sim → Verde 700 (corpo) ou bg SELADO</div>
      <div class="t-q"><strong>Nada disso?</strong></div>
      <div class="t-branch">→ Diamante 700 + neutros. Default institucional.</div>
    </div>

    <div class="tree">
      <h4>Dark-mode: aplicar quando?</h4>
      <div class="t-q"><strong>O usuário tem prefers-color-scheme: dark?</strong></div>
      <div class="t-branch">Sim → aplicar default. Sem perguntar.</div>
      <div class="t-q"><strong>Cofounder PcD CIN P0003 trabalhando noturno?</strong></div>
      <div class="t-branch">Sim → dark-mode override manual disponível.</div>
      <div class="t-q"><strong>Zilda em iluminação ruim, lendo WhatsApp à noite?</strong></div>
      <div class="t-branch">Sim → dark é acessibilidade, não estética.</div>
      <div class="t-q"><strong>Documento institucional impresso/PDF?</strong></div>
      <div class="t-branch">→ light sempre. Print = papel.</div>
    </div>

    <div class="tree">
      <h4>Motion: animar ou static?</h4>
      <div class="t-q"><strong>É feedback funcional (foco/hover/loading)?</strong></div>
      <div class="t-branch">Sim → motion-fast (100ms).</div>
      <div class="t-q"><strong>É transição de estado de componente?</strong></div>
      <div class="t-branch">Sim → motion-standard (200ms).</div>
      <div class="t-q"><strong>É modal/detalhe abrindo?</strong></div>
      <div class="t-branch">Sim → motion-slow (300ms · ease-out).</div>
      <div class="t-q"><strong>É headline, hierarquia, selo, página inteira?</strong></div>
      <div class="t-branch">→ NUNCA mover. Estático sempre.</div>
      <div class="t-q"><strong>prefers-reduced-motion: reduce?</strong></div>
      <div class="t-branch">→ tudo zera. Não negociável.</div>
    </div>
  </div>

  <h3 class="section-head">Três mocks · componentes em contexto</h3>
  <div class="section-sub">WhatsApp Cidadão · ClickUp Beto · Dashboard Cofounder</div>

  <div class="screen-mocks">
    <!-- Mock 1: WhatsApp Cidadão -->
    <div class="screen sc-whats">
      <div class="sc-bar">
        <span>WhatsApp · Zilda</span>
        <span class="sc-mode">Cidadão · pilar Acesso</span>
      </div>
      <div class="sc-body">
        <div class="bubble bot">Bom dia, Dona Zilda. Recebi seu pedido. Vou conferir os papéis com o sindicato — sem pressa, no seu tempo.</div>
        <div class="bubble">Obrigada, meu filho. Tô esperando.</div>
        <div class="bubble bot">A senhora pode mandar foto do seu RG, mesmo amassado serve.</div>
        <div class="bubble bot" style="background:#FAFAF7; border-left:3px solid var(--mc-azul-700);"><strong style="font-family:var(--mc-font-serif); font-size:13px;">Próximo passo</strong><br>Oficial procura sindicato segunda. Senhora não precisa fazer nada agora.</div>
      </div>
    </div>

    <!-- Mock 2: ClickUp Beto -->
    <div class="screen sc-clickup">
      <div class="sc-bar">
        <span>ClickUp · Beto T2</span>
        <span class="sc-mode">Human API · Φ₁</span>
      </div>
      <div class="sc-body">
        <div class="cu-task done"><span>Hib001 · triagem inicial JER001</span><span class="cu-meta">D02 · ok</span></div>
        <div class="cu-task done"><span>Hib001 · Hook 0 gov.br Prata</span><span class="cu-meta">C46 · ok</span></div>
        <div class="cu-task"><span>Hib001 · OAB firewall recursal</span><span class="cu-meta">C72 · ⚠</span></div>
        <div class="cu-task"><span>Hib001 · juntar provas materiais</span><span class="cu-meta">SLA 48h</span></div>
        <div class="cu-task"><span>Hib001 · dossiê final · 4 camadas</span><span class="cu-meta">L1-L4</span></div>
        <div class="cu-task"><span>Hib001 · enviar Dra. Juliana</span><span class="cu-meta">19/05</span></div>
      </div>
    </div>

    <!-- Mock 3: Dashboard Cofounder -->
    <div class="screen sc-cof">
      <div class="sc-bar">
        <span>Dashboard Cofounder</span>
        <span class="sc-mode">D &gt; C &gt; V · live</span>
      </div>
      <div class="sc-body">
        <div class="cof-row"><strong>Casos ativos</strong><span class="cof-val">42</span></div>
        <div class="cof-row"><strong>Rota A · Autonomia</strong><span class="cof-val">8 · 19%</span></div>
        <div class="cof-row"><strong>Rota B · Human API</strong><span class="cof-val">24 · 57%</span></div>
        <div class="cof-row"><strong>Rota C · Marketplace</strong><span class="cof-val">8 · 19%</span></div>
        <div class="cof-row"><strong>Rota D · Interrupção</strong><span class="cof-val">2 · 5%</span></div>
        <div class="cof-row"><strong>Latência média</strong><span class="cof-val">412ms</span></div>
        <div class="cof-row"><strong>D&gt;C&gt;V violations</strong><span class="cof-val" style="color:var(--mc-verde-protecao-corpo)">0</span></div>
        <div class="cof-row"><strong>OAB firewall hits</strong><span class="cof-val">3</span></div>
      </div>
    </div>
  </div>

  <!-- Handoff Carlos UX -->
  <div class="carlos-handoff">
    <h4>Como Carlos UX itera a partir daqui</h4>
    <p>Foundation v0.3 é PROVISIONAL. Sprint visual 1 (pós-Juliana 19/05) selará v1.0. Carlos chega com mandato de:</p>
    <ul>
      <li>Validar 3 explorações de logo (P9) e escolher direção definitiva</li>
      <li>Refinar motion specs com casos de uso reais (não só demonstração)</li>
      <li>Estender componentes institucionais conforme novos casos surgirem</li>
      <li>Cunhar componentes ausentes: navegação principal, breadcrumbs, modais MC, toasts MC, formulário multi-step Zilda</li>
      <li>Estabelecer tokens de produto (separados dos tokens de Foundation)</li>
      <li>Bloquear merge se hierarquia D&gt;C&gt;V não estiver visualmente preservada</li>
    </ul>
    <p style="margin-top:14px;"><strong>Princípio nuclear ao Carlos:</strong> tu não está desenhando app — tu está cunhando instituição. Quando bater dúvida, lembra que Zilda lê, OAB audita, FINEP avalia. Os três simultaneamente.</p>
  </div>

  <div class="rule-strong" style="margin-top: 64px;"></div>
  <div style="display: grid; grid-template-columns: 1fr auto; gap: 32px; margin-top: 32px; align-items: end;">
    <div>
      <div class="page-eyebrow" style="margin-bottom: 12px;">Fim da Foundation v0.3 PROVISIONAL</div>
      <p class="serif" style="font-size: 20px; font-style: italic; color: var(--mc-text-primary); max-width: 560px;">
        "Abre a tua boca a favor do mudo, em juízo de todos os desamparados." — Provérbios 31:8
      </p>
    </div>
    <div class="cover-hash">
      <div>MC · DESIGN SYSTEM</div>
      <div>FOUNDATION · v0.3</div>
      <div>STATUS · PROVISIONAL</div>
      <div>15 · MAI · 2026</div>
      <div>SHA-256 · [placeholder]</div>
    </div>
  </div>
</section>

</main>

<script>
/* ============================================================
   Build palette swatches dynamically with computed WCAG ratios
   Light + Dark contrast cross-tabulated
   ============================================================ */
(function(){
  const families = {
    diamante: {name:'diamante', scale:{50:'#E8ECF3',100:'#C9D2E0',300:'#5F76A0',400:'#2C447A',500:'#0F1E3D',600:'#0B1730',700:'#07101F',800:'#050A14'}},
    ouro:     {name:'ouro',     scale:{50:'#F8F2E2',100:'#EFE2BC',300:'#DCC288',400:'#D3B575',500:'#C9A961',700:'#8C7239'}},
    vermelho: {name:'vermelho', scale:{50:'#F8E5E5',100:'#EBC0C0',300:'#D27575',400:'#C25555',500:'#B33A3A',700:'#7A1F1F'}},
    azul:     {name:'azul',     scale:{50:'#E7ECF4',100:'#C5D0E2',300:'#7A91B6',400:'#5E7CAB',500:'#3E5C8C',700:'#243D63'}},
    verde:    {name:'verde',    scale:{50:'#E4EFEA',100:'#BFD8CB',300:'#7AAE91',400:'#5C9C7C',500:'#3B7B5E',700:'#1F4E3A'}},
  };
  const PAPER = '#FAFAF7', NOITE = '#0A0E1A', DARK = '#050A14';

  function hexToRgb(h){h=h.replace('#','');return[parseInt(h.slice(0,2),16),parseInt(h.slice(2,4),16),parseInt(h.slice(4,6),16)]}
  function lum([r,g,b]){const f=v=>{v/=255;return v<=0.03928?v/12.92:Math.pow((v+0.055)/1.055,2.4)};return 0.2126*f(r)+0.7152*f(g)+0.0722*f(b)}
  function contrast(a,b){const la=lum(hexToRgb(a)),lb=lum(hexToRgb(b));const[L1,L2]=[Math.max(la,lb),Math.min(la,lb)];return((L1+0.05)/(L2+0.05))}
  function grade(r){if(r>=7)return['AAA','cb-pass-aaa'];if(r>=4.5)return['AA','cb-pass-aa'];if(r>=3)return['AA·LG','cb-pass-aa'];return['fail','cb-fail']}
  window.MC = window.MC || {}; window.MC.contrast = contrast; window.MC.grade = grade; window.MC.families = families;

  document.querySelectorAll('[data-family-base]').forEach(host => {
    const fam = families[host.dataset.familyBase];
    const ref = host.dataset.bg === 'dark' ? DARK : PAPER;
    if(!fam) return;
    Object.entries(fam.scale).forEach(([level, hex]) => {
      const cMain = contrast(hex, ref);
      const cAlt  = contrast(hex, host.dataset.bg === 'dark' ? PAPER : NOITE);
      const [gM, clsM] = grade(cMain);
      const [gA, clsA] = grade(cAlt);
      const isLight = lum(hexToRgb(hex)) > 0.5;
      const swatch = document.createElement('div');
      swatch.className = 'swatch';
      swatch.innerHTML = `
        <div class="swatch-chip" style="background:${hex}; color:${isLight ? '#1A1F2C' : '#FAFAF7'};">${level}</div>
        <div class="swatch-meta">
          <div class="swatch-token">--mc-${fam.name}-${level}</div>
          <div class="swatch-hex">${hex.toUpperCase()}</div>
          <div class="swatch-contrast">
            <span class="cb ${host.dataset.bg==='dark'?'cb-dark':'cb-paper'} ${clsM}" title="vs ${host.dataset.bg==='dark'?'fundo-dark':'branco-papel'}">${host.dataset.bg==='dark'?'dark':'papel'} <span class="cb-ratio">${cMain.toFixed(1)}</span><span class="cb-grade">${gM}</span></span>
            <span class="cb ${host.dataset.bg==='dark'?'cb-paper':'cb-noite'} ${clsA}">${host.dataset.bg==='dark'?'papel':'noite'} <span class="cb-ratio">${cAlt.toFixed(1)}</span><span class="cb-grade">${gA}</span></span>
          </div>
        </div>`;
      host.appendChild(swatch);
    });
  });

  /* ============================================================
     Contrast table builder (P8)
     ============================================================ */
  const tokensToReport = [
    {tok:'--mc-diamante-500',  hex:'#0F1E3D'},
    {tok:'--mc-diamante-700',  hex:'#07101F'},
    {tok:'--mc-diamante-800',  hex:'#050A14'},
    {tok:'--mc-vermelho-500',  hex:'#B33A3A'},
    {tok:'--mc-vermelho-700',  hex:'#7A1F1F'},
    {tok:'--mc-vermelho-400',  hex:'#C25555'},
    {tok:'--mc-azul-500',      hex:'#3E5C8C'},
    {tok:'--mc-azul-700',      hex:'#243D63'},
    {tok:'--mc-azul-400',      hex:'#5E7CAB'},
    {tok:'--mc-verde-500',     hex:'#3B7B5E'},
    {tok:'--mc-verde-700',     hex:'#1F4E3A'},
    {tok:'--mc-verde-400',     hex:'#5C9C7C'},
    {tok:'--mc-ouro-500',      hex:'#C9A961'},
    {tok:'--mc-ouro-700',      hex:'#8C7239'},
    {tok:'--mc-papel',         hex:'#FAFAF7'},
    {tok:'--mc-cinza-300',     hex:'#B8B8C2'},
  ];
  const usageMap = {
    '--mc-diamante-500':'BG inverso · headlines · ícones grandes',
    '--mc-diamante-700':'Corpo · headlines · texto institucional',
    '--mc-diamante-800':'BG dark-mode primário',
    '--mc-vermelho-500':'Backgrounds com texto branco · ícones ≥24px',
    '--mc-vermelho-700':'Corpo · texto de risco (light)',
    '--mc-vermelho-400':'Corpo · texto de risco (dark)',
    '--mc-azul-500':'Accents · ícones grandes',
    '--mc-azul-700':'Corpo · pilar Acesso (light)',
    '--mc-azul-400':'Corpo · pilar Acesso (dark)',
    '--mc-verde-500':'Status SELADO bg',
    '--mc-verde-700':'Corpo · proteção (light)',
    '--mc-verde-400':'Corpo · proteção (dark)',
    '--mc-ouro-500':'Selo · borda cerimonial · NUNCA corpo',
    '--mc-ouro-700':'Accent · NUNCA corpo sobre papel',
    '--mc-papel':'BG light · corpo no dark',
    '--mc-cinza-300':'Texto secundário no dark',
  };
  const tbody = document.querySelector('#contrast-table-body');
  if (tbody) {
    tokensToReport.forEach(({tok,hex}) => {
      const cLight = contrast(hex, PAPER);
      const cDark  = contrast(hex, DARK);
      const [gL, clsL] = grade(cLight);
      const [gD, clsD] = grade(cDark);
      const lightCls = cLight>=7?'pass-aaa':(cLight>=4.5?'pass-aa':'fail');
      const darkCls  = cDark >=7?'pass-aaa':(cDark >=4.5?'pass-aa':'fail');
      tbody.insertAdjacentHTML('beforeend', `
        <tr>
          <td class="ct-token"><span class="swatch-dot" style="background:${hex}"></span>${tok}</td>
          <td class="ct-hex">${hex.toUpperCase()}</td>
          <td class="${lightCls}">${cLight.toFixed(2)}:1 · ${gL}</td>
          <td class="${darkCls}">${cDark.toFixed(2)}:1 · ${gD}</td>
          <td class="ct-usage">${usageMap[tok] || ''}</td>
        </tr>`);
    });
  }

  /* ============================================================
     Dark-mode tokens table builder (P2b)
     ============================================================ */
  const darkTokens = [
    {sem:'--mc-bg-primary',     light:'#FAFAF7', dark:'#050A14'},
    {sem:'--mc-bg-secondary',   light:'#FFFFFF', dark:'#07101F'},
    {sem:'--mc-bg-elevated',    light:'#FFFFFF', dark:'#0B1730'},
    {sem:'--mc-text-primary',   light:'#07101F', dark:'#FAFAF7'},
    {sem:'--mc-text-secondary', light:'#555A66', dark:'#B8B8C2'},
    {sem:'--mc-text-disabled',  light:'#B8B8C2', dark:'#5C5C66'},
    {sem:'--mc-border-default', light:'#CFC9BD', dark:'#0B1730'},
    {sem:'--mc-accent-ouro',    light:'#C9A961', dark:'#C9A961'},
    {sem:'--mc-risco-vermelho', light:'#7A1F1F', dark:'#C25555'},
    {sem:'--mc-fluxo-azul',     light:'#243D63', dark:'#5E7CAB'},
    {sem:'--mc-protecao-verde', light:'#1F4E3A', dark:'#5C9C7C'},
  ];
  const dtbody = document.querySelector('#dark-tokens-body');
  if (dtbody) {
    darkTokens.forEach(({sem,light,dark})=>{
      dtbody.insertAdjacentHTML('beforeend', `
        <tr>
          <td class="tok">${sem}</td>
          <td class="val"><span class="sw" style="background:${light}"></span>${light}</td>
          <td class="val"><span class="sw" style="background:${dark}"></span>${dark}</td>
        </tr>`);
    });
  }

  /* ============================================================
     Smooth scroll + IntersectionObserver active TOC
     ============================================================ */
  document.querySelectorAll('.toc a').forEach(a => {
    a.addEventListener('click', e => {
      const t = document.querySelector(a.getAttribute('href'));
      if (t) { e.preventDefault(); t.scrollIntoView({behavior:'smooth', block:'start'}); history.replaceState(null,'',a.getAttribute('href')); }
    });
  });

  const tocLinks = new Map();
  document.querySelectorAll('.toc a[href^="#"]').forEach(a => {
    const id = a.getAttribute('href').slice(1);
    tocLinks.set(id, a);
  });
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e => {
      if (e.isIntersecting) {
        tocLinks.forEach(a => a.removeAttribute('aria-current'));
        const link = tocLinks.get(e.target.id);
        if (link) link.setAttribute('aria-current','location');
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px', threshold: 0 });
  document.querySelectorAll('section.page').forEach(s => io.observe(s));

  /* ============================================================
     Theme toggle (respeita prefers-color-scheme; sem persistência)
     ============================================================ */
  const root = document.documentElement;
  const toggle = document.getElementById('theme-toggle');
  function apply(theme){
    root.setAttribute('data-theme', theme);
    if (toggle) toggle.textContent = theme === 'dark' ? 'Dark' : 'Light';
  }
  if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) apply('dark');
  if (toggle) toggle.addEventListener('click', ()=>{
    apply(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
  });
})();
</script>

</body>
</html>
