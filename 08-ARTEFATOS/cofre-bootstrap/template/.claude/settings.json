{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git fetch origin)",
      "Bash(git pull origin*)",
      "Bash(git push -u origin*)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Bash(git push --force origin main)",
      "Bash(git push --force-with-lease origin main)",
      "Bash(git reset --hard*)",
      "Bash(git filter-branch*)",
      "Bash(rm -rf*)",
      "Bash(Remove-Item -Recurse -Force*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "COFRE_LINT_MODE=block python3 .claude/hooks/cofre-lint.py" } ] }
    ]
  },
  "_metadata": {
    "origem": "cofre-bootstrap (generalizado do harness MC)",
    "lint": "cofre-lint.py (motor) + lint-rules.json (regras DESTE cofre)",
    "nota": "Defina as proibições do cofre em .claude/hooks/lint-rules.json antes de confiar no block-mode."
  }
}
