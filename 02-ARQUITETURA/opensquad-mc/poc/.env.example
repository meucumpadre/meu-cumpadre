# MC-Squad PoC — variáveis de ambiente (COPIE para .env e preencha localmente).
# .env é gitignored — NUNCA commite chaves reais. NUNCA cole chave em chat/PR.

# --- Gemini (provider cloud · zona SEGURA) ----------------------------------
# Obtenha em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Claude / Anthropic (provider cloud · zona SEGURA · decisões éticas) -----
# Obtenha em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- NotebookLM (skill de pesquisa/áudio · zona SEGURA) ---------------------
# NÃO existe API key de consumidor. Escolha um modo:
#   stub        -> offline (default, não chama nada)
#   autocontent -> 3rd-party (tem API key própria)
#   enterprise  -> NotebookLM Enterprise via Vertex (service account, não api key)
#   cli         -> lib não-oficial (frágil, sob risco)
NOTEBOOKLM_MODE=stub

# Modo 'autocontent' (3rd-party):
AUTOCONTENT_API_KEY=

# Modo 'enterprise' (Google Cloud / Vertex — service account):
GCP_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
